<div class="gw-section"><style>.gw-section{background:linear-gradient(135deg,#0f0c29,#302b63,#24243e);padding:64px 20px;font-family:inherit;position:relative;overflow:hidden}.gw-section::before{content:'';position:absolute;inset:0;background:radial-gradient(ellipse at 30% 50%,rgba(168,85,247,.25),transparent 60%),radial-gradient(ellipse at 70% 50%,rgba(245,158,11,.2),transparent 60%);pointer-events:none}.gw-inner{max-width:560px;margin:0 auto;position:relative;background:rgba(255,255,255,.06);backdrop-filter:blur(16px);border-radius:28px;padding:52px 44px;border:2px solid rgba(255,215,0,.4);box-shadow:0 0 0 1px rgba(168,85,247,.3),0 8px 80px rgba(106,13,173,.7),0 0 160px rgba(245,158,11,.15);text-align:center}.gw-emoji{font-size:4rem;display:block;margin-bottom:8px;animation:bounce 2s infinite}.gw-title{font-size:2.1rem;font-weight:900;color:#ffd700;margin:0 0 6px;text-shadow:0 0 30px rgba(255,215,0,.7),0 2px 4px rgba(0,0,0,.5);letter-spacing:.01em}.gw-sub{color:rgba(255,255,255,.8);font-size:.925rem;margin:0 0 24px;line-height:1.65}.gw-prizes{display:flex;justify-content:center;gap:10px;margin-bottom:28px;flex-wrap:wrap}.gw-prize{background:rgba(255,215,0,.1);border:1px solid rgba(255,215,0,.4);border-radius:14px;padding:10px 18px;color:#fff;font-size:.85rem;line-height:1.5;transition:transform .2s}.gw-prize:hover{transform:translateY(-2px)}.gw-prize strong{color:#ffd700;font-size:1.15rem;display:block;font-weight:800}.gw-form{display:flex;flex-direction:column;gap:13px}.gw-inp{padding:14px 18px;border-radius:14px;border:2px solid rgba(255,215,0,.2);background:rgba(255,255,255,.08);color:#fff;font-size:.95rem;outline:none;transition:border-color .25s,background .25s;width:100%;box-sizing:border-box}.gw-inp::placeholder{color:rgba(255,255,255,.4)}.gw-inp:focus{border-color:#ffd700;background:rgba(255,255,255,.13)}.gw-code{font-family:monospace;letter-spacing:.12em;text-transform:uppercase;font-weight:800;text-align:center;font-size:1.05rem;color:#ffd700}.gw-btn{padding:16px;background:linear-gradient(90deg,#f59e0b,#ffd700,#f59e0b);background-size:200% 100%;color:#1a0a00;font-weight:900;font-size:1.1rem;border:none;border-radius:14px;cursor:pointer;transition:transform .15s,box-shadow .15s;animation:shimmer 2.5s linear infinite;margin-top:6px;letter-spacing:.03em}.gw-btn:hover:not(:disabled){transform:translateY(-3px);box-shadow:0 10px 32px rgba(245,158,11,.6)}.gw-btn:disabled{opacity:.5;cursor:not-allowed;transform:none;animation:none}.gw-msg{margin-top:10px;font-size:.875rem;min-height:1.4em;font-weight:500}.gw-msg.err{color:#ff6b6b}.gw-msg.ok{color:#69db7c}.gw-popup{display:none;position:fixed;inset:0;background:rgba(0,0,0,.8);z-index:999999;align-items:center;justify-content:center;padding:20px;backdrop-filter:blur(4px)}.gw-popup.on{display:flex}.gw-pbox{background:linear-gradient(135deg,#1a0533,#6a0dad);border:3px solid #ffd700;border-radius:28px;padding:52px 40px;text-align:center;max-width:420px;width:100%;box-shadow:0 0 120px rgba(255,215,0,.5);animation:popIn .45s cubic-bezier(.175,.885,.32,1.275)}.gw-picon{font-size:4.5rem;display:block;margin-bottom:16px;animation:bounce .6s .45s both}.gw-ptitle{font-size:1.9rem;font-weight:900;color:#ffd700;margin:0 0 14px;text-shadow:0 0 20px rgba(255,215,0,.6)}.gw-ptext{color:rgba(255,255,255,.9);font-size:.975rem;line-height:1.7;margin:0 0 28px}.gw-pclose{background:linear-gradient(90deg,#f59e0b,#ffd700);color:#1a0a00;border:none;padding:13px 36px;border-radius:99px;font-weight:900;font-size:1rem;cursor:pointer;transition:transform .15s,box-shadow .15s}.gw-pclose:hover{transform:translateY(-2px);box-shadow:0 6px 20px rgba(245,158,11,.5)}@keyframes popIn{from{transform:scale(.3) rotate(-10deg);opacity:0}to{transform:scale(1) rotate(0);opacity:1}}@keyframes bounce{0%,100%{transform:translateY(0)}50%{transform:translateY(-8px)}}@keyframes shimmer{0%{background-position:0% 0}100%{background-position:200% 0}}@media(max-width:600px){.gw-inner{padding:36px 20px}.gw-title{font-size:1.6rem}.gw-pbox{padding:36px 24px}}</style><div class="gw-inner"><span class="gw-emoji">🎰</span><h2 class="gw-title">Piedalies Izlozē!</h2><p class="gw-sub">Ievadi savus datus un izlozes kodu, lai piedalītos.<br>Par katru iztērēto <strong style="color:#ffd700">€1</strong> tu saņem <strong style="color:#ffd700">1 dalības biļeti!</strong></p><div class="gw-prizes"><div class="gw-prize"><strong>🥇 €50</strong>1. vieta</div><div class="gw-prize"><strong>🥈 €20</strong>2. vieta</div><div class="gw-prize"><strong>🥉 €10</strong>3. vieta</div></div><form class="gw-form" onsubmit="return false"><input class="gw-inp gw-code" id="gwCode" type="text" placeholder="🔑 Ievadi kodu: WinCash26" maxlength="20" autocomplete="off"><input class="gw-inp" id="gwName" type="text" placeholder="👤 Vārds un Uzvārds"><input class="gw-inp" id="gwPhone" type="tel" placeholder="📞 Tālruņa numurs"><input class="gw-inp" id="gwEmail" type="email" placeholder="📧 E-pasta adrese"><button class="gw-btn" id="gwBtn" type="button" onclick="gwJoin()">🎯 Piedalīties Izlozē!</button><div class="gw-msg" id="gwMsg"></div></form></div></div><div class="gw-popup" id="gwPopup"><div class="gw-pbox"><span class="gw-picon">🎉</span><div class="gw-ptitle">Apsveicu!</div><div class="gw-ptext">Tu esi veiksmīgi pieteicies izlozei!<br><br>Mēs sazināsimies ar uzvarētājiem.<br><br>Laimīgu zvaigžņu zīmi! ⭐</div><button class="gw-pclose" onclick="document.getElementById('gwPopup').classList.remove('on')">Lieliski! 🎊</button></div></div><script>window.gwJoin=async function(){var btn=document.getElementById('gwBtn'),msg=document.getElementById('gwMsg'),code=document.getElementById('gwCode').value.trim().toUpperCase(),name=document.getElementById('gwName').value.trim(),phone=document.getElementById('gwPhone').value.trim(),email=document.getElementById('gwEmail').value.trim();msg.className='gw-msg';if(!code||!name||!phone||!email){msg.textContent='⚠️ Lūdzu aizpildi visus laukus!';msg.className='gw-msg err';return}if(code!=='WINCASH26'){msg.textContent='❌ Nepareizs kods. Pārbaudi un mēģini vēlreiz!';msg.className='gw-msg err';return}if(!email.includes('@')||!email.includes('.')){msg.textContent='❌ Ievadi derīgu e-pasta adresi!';msg.className='gw-msg err';return}if(phone.replace(/[\s\-+()]/g,'').length<7){msg.textContent='❌ Ievadi derīgu tālruņa numuru!';msg.className='gw-msg err';return}btn.disabled=true;btn.textContent='⏳ Reģistrē...';var stored=localStorage.getItem('gw_entered_'+email);if(stored){document.getElementById('gwPopup').classList.add('on');document.querySelector('.gw-form').style.opacity='.3';document.querySelector('.gw-form').style.pointerEvents='none';btn.textContent='✅ Pieteicies!';return}try{var cid={{ customer.id | default: 0 }};var resp=await fetch('https://protective-compassion-production-ff43.up.railway.app/giveaway/enter',{method:'POST',headers:{'Content-Type':'application/json'},body:JSON.stringify({code:code,name:name,phone:phone,email:email,customerId:cid||('guest_'+Date.now())})});var data=await resp.json();if(data.success||data.message){localStorage.setItem('gw_entered_'+email,'1');document.getElementById('gwPopup').classList.add('on');document.querySelector('.gw-form').style.opacity='.3';document.querySelector('.gw-form').style.pointerEvents='none';btn.textContent='✅ Pieteicies!'}else{btn.disabled=false;btn.textContent='🎯 Piedalīties Izlozē!';msg.textContent='❌ '+(data.message||'Kļūda. Mēģini vēlreiz!');msg.className='gw-msg err'}}catch(e){btn.disabled=false;btn.textContent='🎯 Piedalīties Izlozē!';msg.textContent='❌ Servera kļūda. Mēģini vēlreiz!';msg.className='gw-msg err'}};</script>{% schema %}{"name":"Izloze — Forma","tag":"section","class":"giveaway-section-outer","settings":[],"presets":[{"name":"Izloze — Forma"}]}{% endschema %}
