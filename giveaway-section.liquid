<div class="gw-wrap">
  <div class="gw-card">
    <div class="gw-left">
      <div class="gw-badge">🎰 IZLOZE</div>
      <h2 class="gw-title">Piedalies un laimē!</h2>
      <p class="gw-desc">Ievadi slepeno kodu un reģistrējies izlozē. Par katru iztērēto <strong>€1</strong> tu saņem papildus biļeti!</p>
      <div class="gw-prizes">
        <div class="gw-prize"><span>🥇</span><div><strong>€50</strong><small>1. vieta</small></div></div>
        <div class="gw-prize"><span>🥈</span><div><strong>€20</strong><small>2. vieta</small></div></div>
        <div class="gw-prize"><span>🥉</span><div><strong>€10</strong><small>3. vieta</small></div></div>
      </div>
    </div>
    <div class="gw-right">
      <form id="gwForm" onsubmit="return false">
        <div class="gw-field"><label class="gw-label">Slepenais kods</label><input class="gw-input gw-code" id="gwCode" type="text" placeholder="Ievadi kodu šeit..." maxlength="20" autocomplete="off"></div>
        <div class="gw-field"><label class="gw-label">Vārds un Uzvārds</label><input class="gw-input" id="gwName" type="text" placeholder="Jānis Bērziņš"></div>
        <div class="gw-row">
          <div class="gw-field"><label class="gw-label">Tālrunis</label><input class="gw-input" id="gwPhone" type="tel" placeholder="+371 20000000"></div>
          <div class="gw-field"><label class="gw-label">E-pasts</label><input class="gw-input" id="gwEmail" type="email" placeholder="janis@inbox.lv"></div>
        </div>
        <button class="gw-btn" id="gwBtn" type="button" onclick="gwSubmit()">Piedalīties izlozē →</button>
        <p class="gw-msg" id="gwMsg"></p>
      </form>
    </div>
  </div>
</div>
<div class="gw-overlay" id="gwOverlay">
  <div class="gw-modal">
    <div class="gw-modal-icon">🎉</div>
    <h3 class="gw-modal-title">Apsveicu!</h3>
    <p class="gw-modal-text">Tu esi veiksmīgi pieteicies izlozei!<br>Mēs sazināsimies ar uzvarētājiem.<br><br>⭐ Laimīgu zvaigžņu zīmi!</p>
    <button class="gw-modal-close" onclick="document.getElementById('gwOverlay').style.display='none'">Aizvērt</button>
  </div>
</div>
<style>
.gw-wrap{padding:60px 16px;background:#f8f6f2}
.gw-card{max-width:1080px;margin:0 auto;background:#fff;border-radius:16px;overflow:hidden;display:grid;grid-template-columns:1fr 1fr;box-shadow:0 4px 32px rgba(0,0,0,.1);border:1px solid #e5e1da}
.gw-left{background:linear-gradient(145deg,#1a1a2e,#0f3460);padding:52px 44px;display:flex;flex-direction:column;justify-content:center}
.gw-badge{display:inline-block;background:rgba(255,215,0,.15);border:1px solid rgba(255,215,0,.4);color:#ffd700;font-size:.75rem;font-weight:700;letter-spacing:.1em;padding:5px 14px;border-radius:99px;margin-bottom:20px;width:fit-content}
.gw-title{font-size:2rem;font-weight:800;color:#fff;margin:0 0 14px;line-height:1.25}
.gw-desc{color:rgba(255,255,255,.75);font-size:.9375rem;line-height:1.7;margin:0 0 28px}
.gw-desc strong{color:#ffd700}
.gw-prizes{display:flex;flex-direction:column;gap:10px}
.gw-prize{display:flex;align-items:center;gap:12px;background:rgba(255,255,255,.06);border:1px solid rgba(255,255,255,.1);border-radius:10px;padding:12px 16px}
.gw-prize span{font-size:1.375rem}
.gw-prize div{display:flex;flex-direction:column;gap:2px}
.gw-prize strong{color:#ffd700;font-size:1.0625rem;font-weight:800;line-height:1}
.gw-prize small{color:rgba(255,255,255,.6);font-size:.8125rem}
.gw-right{padding:48px 44px;display:flex;align-items:center}
.gw-right form{width:100%}
.gw-field{margin-bottom:16px}
.gw-row{display:grid;grid-template-columns:1fr 1fr;gap:14px;margin-bottom:16px}
.gw-row .gw-field{margin-bottom:0}
.gw-label{display:block;font-size:.8125rem;font-weight:600;color:#374151;margin-bottom:6px}
.gw-input{width:100%;padding:11px 14px;border:1.5px solid #d1d5db;border-radius:10px;font-size:.9375rem;color:#111;background:#fff;outline:none;transition:border-color .2s;box-sizing:border-box;font-family:inherit}
.gw-input:focus{border-color:#1a1a2e;box-shadow:0 0 0 3px rgba(26,26,46,.08)}
.gw-code{font-family:monospace;letter-spacing:.06em;text-transform:uppercase;font-weight:700;color:#1a1a2e}
.gw-input::placeholder{color:#9ca3af;font-family:inherit;letter-spacing:0;text-transform:none;font-weight:400}
.gw-btn{width:100%;padding:14px;background:#1a1a2e;color:#ffd700;font-weight:700;font-size:1rem;border:none;border-radius:10px;cursor:pointer;transition:background .2s,transform .15s;margin-top:6px;font-family:inherit;letter-spacing:.02em}
.gw-btn:hover:not(:disabled){background:#0f3460;transform:translateY(-1px)}
.gw-btn:disabled{opacity:.5;cursor:not-allowed;transform:none}
.gw-msg{margin:8px 0 0;font-size:.8125rem;text-align:center;min-height:1.2em}
.gw-msg.err{color:#dc2626}
.gw-msg.ok{color:#16a34a}
.gw-overlay{display:none;position:fixed;inset:0;background:rgba(0,0,0,.6);z-index:99999;align-items:center;justify-content:center;padding:20px}
.gw-overlay.open{display:flex}
.gw-modal{background:#fff;border-radius:20px;padding:48px 36px;text-align:center;max-width:400px;width:100%;box-shadow:0 20px 60px rgba(0,0,0,.25);animation:gwPop .35s cubic-bezier(.175,.885,.32,1.275)}
.gw-modal-icon{font-size:3.5rem;margin-bottom:12px}
.gw-modal-title{font-size:1.625rem;font-weight:800;color:#1a1a2e;margin:0 0 12px}
.gw-modal-text{color:#6b7280;font-size:.9375rem;line-height:1.7;margin:0 0 24px}
.gw-modal-close{background:#1a1a2e;color:#ffd700;border:none;padding:12px 32px;border-radius:99px;font-weight:700;font-size:.9375rem;cursor:pointer;font-family:inherit}
.gw-modal-close:hover{background:#0f3460}
@keyframes gwPop{from{transform:scale(.7);opacity:0}to{transform:scale(1);opacity:1}}
@media(max-width:768px){.gw-card{grid-template-columns:1fr}.gw-left,.gw-right{padding:36px 24px}.gw-row{grid-template-columns:1fr}.gw-title{font-size:1.5rem}}
</style>
<script>
window.gwSubmit = async function() {
  var btn = document.getElementById('gwBtn');
  var msg = document.getElementById('gwMsg');
  var code = (document.getElementById('gwCode').value || '').trim().toUpperCase();
  var name = (document.getElementById('gwName').value || '').trim();
  var phone = (document.getElementById('gwPhone').value || '').trim();
  var email = (document.getElementById('gwEmail').value || '').trim();
  msg.className = 'gw-msg'; msg.textContent = '';
  if (!code || !name || !phone || !email) {
    msg.textContent = 'Lūdzu aizpildi visus laukus.';
    msg.className = 'gw-msg err'; return;
  }
  if (code !== 'WINCASH26') {
    msg.textContent = 'Nepareizs kods — pārbaudi un mēģini vēlreiz!';
    msg.className = 'gw-msg err'; return;
  }
  if (!email.includes('@') || !email.includes('.')) {
    msg.textContent = 'Ievadi derīgu e-pasta adresi.';
    msg.className = 'gw-msg err'; return;
  }
  btn.disabled = true; btn.textContent = 'Reģistrē...';
  try {
    var resp = await fetch('https://protective-compassion-production-ff43.up.railway.app/giveaway/enter', {
      method: 'POST',
      headers: { 'Content-Type': 'application/json' },
      body: JSON.stringify({ code: code, name: name, phone: phone, email: email, customerId: 'guest_' + Date.now() })
    });
    var data = await resp.json();
    if (data.success || data.alreadyEntered || data.entries >= 0 || data.message) {
      var ov = document.getElementById('gwOverlay');
      ov.style.display = 'flex'; ov.className = 'gw-overlay open';
      document.getElementById('gwForm').style.opacity = '.35';
      document.getElementById('gwForm').style.pointerEvents = 'none';
      btn.textContent = 'Pietecies!';
    } else {
      btn.disabled = false; btn.textContent = 'Piedalīties izlozē →';
      msg.textContent = data.message || 'Kaut kas nogāja greizi.';
      msg.className = 'gw-msg err';
    }
  } catch (e) {
    btn.disabled = false; btn.textContent = 'Piedalīties izlozē →';
    msg.textContent = 'Savienojuma kļūda. Mēģini vēlreiz!';
    msg.className = 'gw-msg err';
  }
};
</script>

